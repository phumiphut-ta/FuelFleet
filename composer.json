{
    "name": "phumiphut/fuel-fleet",
    "description": "Fleet Fuel Management & Vehicle Booking System",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "mpdf/mpdf": "^8.2",
        "phpoffice/phpspreadsheet": "^2.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "mpdf/qrcode": true
        }
    }
}
